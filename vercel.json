{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 10,
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/bot", "destination": "/api/webhook.ts" },
    { "source": "/api/webhook", "destination": "/api/webhook.ts" }
  ]
}
